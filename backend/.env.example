# ===================================
# 租房避坑局 - 环境配置示例
# ===================================
# 复制此文件为 .env 并填入真实的 API Key

# ===================================
# Claude API 配置（主要使用）
# ===================================
# Claude 中转地址
CLAUDE_BASE_URL=https://web.codetab.cc

# Opus 模型 API Key（用于复杂任务：Owl Analyst, Cat Reporter）
CLAUDE_API_KEY_OPUS=sk-e53d95dd63a3a5b2df06969b385f5dd9b2b867c529fbd8af564b1b61867f6862
CLAUDE_MODEL_OPUS=claude-opus-4-6

# Sonnet 模型 API Key（用于简单任务：Beaver Calculator, Dog Retriever）
CLAUDE_API_KEY_SONNET=sk-2894874a0d67de3ecd52679587579165f6a0e9eec55564f87fa3ac292d1ffa6f
CLAUDE_MODEL_SONNET=claude-sonnet-4-6

# ===================================
# OpenAI Relay 配置（备用）
# ===================================
# 如使用中转，请填写中转地址；直连 OpenAI 官方则保留默认 /v1
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4

# ===================================
# Anthropic API 配置（已弃用）
# ===================================
# 已改用 Claude 中转，此配置保留用于兼容性
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ===================================
# 千问 Embedding 配置
# ===================================
# 用于知识库向量检索
# 获取地址: https://dashscope.console.aliyun.com/apiKey
EMBEDDING_API_KEY=sk-your-qwen-embedding-api-key-here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v1

# ===================================
# JWT 安全配置
# ===================================
# 用于用户认证（生产环境请修改为随机字符串）
JWT_SECRET_KEY=your-secret-key-change-in-production-please-use-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===================================
# 服务配置
# ===================================
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:5173

# ===================================
# 文件上传配置
# ===================================
MAX_FILE_SIZE=52428800
UPLOAD_DIR=data/uploads

# ===================================
# Supabase 配置（用户偏好存储）
# ===================================
# 用于存储用户偏好和个性化风险判断
# 获取地址: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
