# ===================================
# 租房避坑局 - backend/.env 示例
# ===================================
# 复制本文件为 backend/.env 后，再填入你自己的真实配置
# 注意：不要把真实密钥提交到 GitHub

# ===================================
# OpenAI / OpenAI-compatible
# ===================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4

# ===================================
# Qwen
# ===================================
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
QWEN_MODEL=qwen-max

# ===================================
# Claude / relay
# ===================================
CLAUDE_BASE_URL=https://your-relay.example.com
CLAUDE_API_KEY_OPUS=your-claude-opus-key
CLAUDE_MODEL_OPUS=claude-opus-4-6
CLAUDE_API_KEY_SONNET=your-claude-sonnet-key
CLAUDE_MODEL_SONNET=claude-sonnet-4-6
CLAUDE_API_KEY_BEAVER=your-beaver-dedicated-key
CLAUDE_BASE_URL_BEAVER=https://your-beaver-relay.example.com
CLAUDE_MODEL_BEAVER=claude-opus-4-6

# ===================================
# Embedding
# ===================================
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v1

# ===================================
# JWT / API
# ===================================
JWT_SECRET_KEY=replace-with-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

API_HOST=0.0.0.0
API_PORT=8010
FRONTEND_URL=http://localhost:5173

# ===================================
# Uploads
# ===================================
MAX_FILE_SIZE=52428800
UPLOAD_DIR=data/uploads

# ===================================
# Supabase
# ===================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===================================
# AI provider secret encryption
# ===================================
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this stable in production. Changing it makes saved provider API keys undecryptable.
AI_PROVIDER_ENCRYPTION_KEY=replace-with-fernet-key
